# Copy to .env or run: bash scripts/collect_qa_env.sh
# Optional: HB_QA_ENV=/path/to/alternate.env
#
# Exchange credentials (for MCP / setup_connector; used by collect_qa_env.sh)
API_KEY=
SECRET=
TRADING_PASSWORD=

# --- hummingbot-api HTTP (routers match your local hummingbot-api clone) ---
# Basic Auth: same as USERNAME / PASSWORD in hummingbot-api .env (defaults below).
HUMMINGBOT_API_URL=http://127.0.0.1:8000
HUMMINGBOT_API_USER=admin
HUMMINGBOT_API_PASSWORD=admin

# Account + connector under test (credentials must exist on that API account)
HB_ACCOUNT=master_account
HB_CONNECTOR=binance
HB_TRADING_PAIR=BTC-USDT
# Optional comma-separated list for §2 prices call
# HB_TRADING_PAIRS=BTC-USDT,ETH-USDT

# §4 trading script (uses real orders unless HB_SKIP_MARKET=1)
HB_TEST_ORDER_AMOUNT=0.001
HB_LIMIT_OFFSET_PCT=10
# HB_SKIP_MARKET=1

# §5 perpetual — mutating tests off by default
# HB_LEVERAGE_TEST=1
# HB_POSITION_MODE_WRITE_TEST=1

# §6 DEX / Gateway (GET /gateway/clmm/pools, POST /gateway/swap/quote, …)
HB_DEX_CLMM_CONNECTOR=meteora
HB_DEX_SWAP_CONNECTOR=jupiter
HB_DEX_NETWORK=solana-mainnet-beta
HB_DEX_PAIR=SOL-USDC
# HB_CLMM_NETWORK=solana-mainnet-beta
# HB_CLMM_POOL_ADDRESS=
